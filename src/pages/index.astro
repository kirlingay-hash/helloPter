---
import { getCollection } from 'astro:content';
import ArticleCard from '../components/ArticleCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { sortPosts } from '../lib/blog';
import blogConfig from '../../blog.config.mjs';

const posts = sortPosts(await getCollection('blog'));
const featuredPosts = posts.slice(0, 6);
---

<BaseLayout title={blogConfig.siteName} description={blogConfig.description} canonicalPath="/">
  <section class="hero section-stack">
    <p class="eyebrow">Home Base</p>
    <h1>{blogConfig.siteName}</h1>
    <p class="page-intro">
      聚焦社交平台增长、内容定位和账号运营，把文章、标签、检索与归档做成更利于探索的内容中枢。
    </p>
    <div class="hero-actions">
      <a class="button-link" href="/blog.html">Browse posts</a>
      <a class="button-link button-link--ghost" href="/sidebar.html">View sidebar</a>
      <a class="button-link button-link--ghost" href="/search.html">Search</a>
    </div>
  </section>

  <section class="grid grid--cards">
    {featuredPosts.map((post) => <ArticleCard post={post} />)}
  </section>
</BaseLayout>
